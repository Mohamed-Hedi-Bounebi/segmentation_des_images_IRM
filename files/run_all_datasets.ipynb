   "source": [
    "# 🧠 nnUNetv2 — Dataset Conversion Pipeline\n",
    "\n",
    "Ce notebook permet de :\n",
    "1. Configurer l'environnement nnUNet\n",
    "2. Convertir chaque dataset au format nnUNetv2\n",
    "3. Vérifier que les conversions sont correctes\n",
    "\n",
    "---\n",
    "**Prérequis** : Avoir installé `nnunetv2` et configuré les variables d'environnement."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b2c3d4e5",
   "metadata": {},
   "source": [
    "## 📦 Étape 1 : Installation des dépendances"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c3d4e5f6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Installation des dépendances\n",
    "import subprocess, sys\n",
    "\n",
    "def install(package):\n",
    "    subprocess.check_call([sys.executable, '-m', 'pip', 'install', package, '-q'])\n",
    "\n",
    "packages = ['nnunetv2', 'SimpleITK', 'nibabel', 'tqdm', 'pandas']\n",
    "for pkg in packages:\n",
    "    print(f'Installing {pkg}...')\n",
    "    install(pkg)\n",
    "\n",
    "print('\\n✅ Toutes les dépendances sont installées !')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d4e5f6g7",
   "metadata": {},
   "source": [
    "## 🔧 Étape 2 : Configuration des variables d'environnement"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e5f6g7h8",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "# ⚠️ MODIFIEZ CES CHEMINS selon votre configuration\n",
    "os.environ['nnUNet_raw']           = '/path/to/nnUNet_raw'\n",
    "os.environ['nnUNet_preprocessed']  = '/path/to/nnUNet_preprocessed'\n",
    "os.environ['nnUNet_results']       = '/path/to/nnUNet_results'\n",
    "\n",
    "# Vérification\n",
    "for var in ['nnUNet_raw', 'nnUNet_preprocessed', 'nnUNet_results']:\n",
    "    path = os.environ.get(var, 'NON DÉFINI')\n",
    "    status = '✅' if os.path.exists(path) else '⚠️  (chemin inexistant)'\n",
    "    print(f'{status}  {var} = {path}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f6g7h8i9",
   "metadata": {},
   "source": [
    "## 📋 Étape 3 : Liste de tous les datasets disponibles"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "g7h8i9j0",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, glob\n",
    "import pandas as pd\n",
    "\n",
    "# Récupérer tous les scripts de conversion\n",
    "scripts_dir = os.path.join(os.path.dirname(os.getcwd()), 'dataset_conversion')\n",
    "scripts = sorted(glob.glob(os.path.join(scripts_dir, 'Dataset*.py')))\n",
    "\n",
    "# Affichage sous forme de tableau\n",
    "data = []\n",
    "for s in scripts:\n",
    "    name = os.path.basename(s).replace('.py', '')\n",
    "    parts = name.split('_', 1)\n",
    "    dataset_id = parts[0].replace('Dataset', '')\n",
    "    dataset_name = parts[1] if len(parts) > 1 else ''\n",
    "    size = os.path.getsize(s) / 1024\n",
    "    data.append({'ID': dataset_id, 'Nom': dataset_name, 'Fichier': os.path.basename(s), 'Taille (KB)': round(size, 1)})\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "print(f'📦 {len(df)} datasets trouvés :\\n')\n",
    "display(df)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h8i9j0k1",
   "metadata": {},
   "source": [
    "## ▶️ Étape 4 : Exécuter la conversion d'un dataset spécifique"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "i9j0k1l2",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys, os\n",
    "\n",
    "# ⚠️ Choisissez le dataset à convertir\n",
    "DATASET_SCRIPT = 'Dataset027_ACDC.py'  # <-- Modifiez ici\n",
    "\n",
    "scripts_dir = '../dataset_conversion'\n",
    "script_path = os.path.join(scripts_dir, DATASET_SCRIPT)\n",
    "\n",
    "if not os.path.exists(script_path):\n",
    "    print(f'❌ Script non trouvé : {script_path}')\n",
    "else:\n",
    "    print(f'▶️  Exécution de : {DATASET_SCRIPT}\\n')\n",
    "    result = subprocess.run(\n",
    "        [sys.executable, script_path],\n",
    "        capture_output=True, text=True\n",
    "    )\n",
    "    print(result.stdout)\n",
    "    if result.returncode != 0:\n",
    "        print('❌ ERREUR :')\n",
    "        print(result.stderr)\n",
    "    else:\n",
    "        print('\\n✅ Conversion terminée avec succès !')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "j0k1l2m3",
   "metadata": {},
   "source": [
    "## 🔄 Étape 5 : Exécuter TOUS les datasets en séquence"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "k1l2m3n4",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys, os, glob\n",
    "from tqdm.notebook import tqdm\n",
    "\n",
    "scripts_dir = '../dataset_conversion'\n",
    "all_scripts = sorted(glob.glob(os.path.join(scripts_dir, 'Dataset*.py')))\n",
    "\n",
    "results_log = []\n",
    "\n",
    "print(f'🚀 Lancement de {len(all_scripts)} conversions...\\n')\n",
    "\n",
    "for script in tqdm(all_scripts, desc='Conversion datasets'):\n",
    "    name = os.path.basename(script)\n",
    "    result = subprocess.run(\n",
    "        [sys.executable, script],\n",
    "        capture_output=True, text=True\n",
    "    )\n",
    "    status = '✅' if result.returncode == 0 else '❌'\n",
    "    results_log.append({'Script': name, 'Statut': status, 'Erreur': result.stderr[:100] if result.returncode != 0 else ''})\n",
    "    print(f'{status}  {name}')\n",
    "\n",
    "print('\\n📊 Résumé :')\n",
    "df_results = pd.DataFrame(results_log)\n",
    "success = (df_results['Statut'] == '✅').sum()\n",
    "failed  = (df_results['Statut'] == '❌').sum()\n",
    "print(f'   Réussis : {success}/{len(all_scripts)}')\n",
    "print(f'   Échoués : {failed}/{len(all_scripts)}')\n",
    "display(df_results)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "l2m3n4o5",
   "metadata": {},
   "source": [
    "## 🗂️ Étape 6 : Générer le dataset.json"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "m3n4o5p6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys, os\n",
    "\n",
    "# ⚠️ Configurez ces paramètres selon votre dataset\n",
    "OUTPUT_DIR     = os.path.join(os.environ['nnUNet_raw'], 'Dataset027_ACDC')  # Modifiez\n",
    "CHANNEL_NAMES  = '{\"0\": \"MRI\"}'                                              # Modifiez\n",
    "LABELS         = '{\"background\": 0, \"RV\": 1, \"MYO\": 2, \"LV\": 3}'           # Modifiez\n",
    "NUM_CASES      = '200'                                                        # Modifiez\n",
    "\n",
    "script_path = '../dataset_conversion/generate_dataset_json.py'\n",
    "\n",
    "result = subprocess.run([\n",
    "    sys.executable, script_path,\n",
    "    '--output_dir',        OUTPUT_DIR,\n",
    "    '--channel_names',     CHANNEL_NAMES,\n",
    "    '--labels',            LABELS,\n",
    "    '--num_training_cases', NUM_CASES\n",
    "], capture_output=True, text=True)\n",
    "\n",
    "print(result.stdout)\n",
    "if result.returncode != 0:\n",
    "    print('❌ Erreur :')\n",
    "    print(result.stderr)\n",
    "else:\n",
    "    print('✅ dataset.json généré avec succès !')\n",
    "    json_path = os.path.join(OUTPUT_DIR, 'dataset.json')\n",
    "    if os.path.exists(json_path):\n",
    "        import json\n",
    "        with open(json_path) as f:\n",
    "            print(json.dumps(json.load(f), indent=2))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "n4o5p6q7",
   "metadata": {},
   "source": [
    "## 🔍 Étape 7 : Vérification de la structure du dataset converti"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "o5p6q7r8",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "nnunet_raw = os.environ.get('nnUNet_raw', 'Non défini')\n",
    "\n",
    "print(f'📁 Contenu de nnUNet_raw : {nnunet_raw}\\n')\n",
    "\n",
    "if os.path.exists(nnunet_raw):\n",
    "    for dataset_folder in sorted(os.listdir(nnunet_raw)):\n",
    "        full_path = os.path.join(nnunet_raw, dataset_folder)\n",
    "        if os.path.isdir(full_path):\n",
    "            subdirs = os.listdir(full_path)\n",
    "            has_json    = '✅' if 'dataset.json' in subdirs else '❌'\n",
    "            has_imagesTr = '✅' if 'imagesTr' in subdirs else '❌'\n",
    "            has_labelsTr = '✅' if 'labelsTr' in subdirs else '❌'\n",
    "            print(f'📂 {dataset_folder}')\n",
    "            print(f'   dataset.json: {has_json}  imagesTr: {has_imagesTr}  labelsTr: {has_labelsTr}')\n",
    "else:\n",
    "    print('⚠️  Chemin nnUNet_raw non trouvé. Vérifiez la configuration à l\\'Étape 2.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "p6q7r8s9",
